# XServer MCP Server credentials
# Copy to .env and fill in your values. .env is gitignored.

# Required: your XServer API key (Bearer token)
XSERVER_API_KEY=your-api-key

# Required: your XServer servername
# https://developer.xserver.ne.jp/api/server/#common-spec
# エックスサーバー	サーバーID.xsrv.jp
# XServerビジネス	サーバーID.xbiz.jp
XSERVER_SERVERNAME=your-servername

# Optional: override API base URL (defaults to https://api.xserver.ne.jp)
# XSERVER_BASE_URL=https://api.xserver.ne.jp
